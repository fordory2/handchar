        <!-- ISTA detail box -->
        <mxCell id="ista_det" value="ISTA 迭代细节 (每 stage 独立参数):&lt;br&gt;━━━━━━━━━━━━━━━━━━━━━━━&lt;br&gt;z₀ = mean(x, dim=[H,W])          ← 通道描述子&lt;br&gt;for k in 0..K-1:&lt;br&gt;  h = SiLU(W_e[k]·z_k)            ← 过完备投影→非线性&lt;br&gt;  r = W_s[k]·h                  ← 稀疏重建&lt;br&gt;  z_{k+1} = S_θ(z_k + r)          ← 软阈值: sign·relu(|x|-θ)&lt;br&gt;scale = tanh(z_K − z₀)·0.5+0.5  ← 归一化到 [0,1]&lt;br&gt;out = x × scale                  ← 通道重标定" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#FFF8E1;strokeColor=#F57F17;fontSize=9;align=left;spacingLeft=8;fontFamily=Courier New;" vertex="1" parent="1">
